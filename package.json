{
  "name": "resume-ai",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "set-env": "node scripts/set-env.js",
    "start": "npm run set-env && ng serve",
    "build": "npm run set-env && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:resume-ai": "node dist/resume-ai/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.4.2",
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/cdk": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-server": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/ssr": "^20.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/jspdf": "^1.3.3",
    "chart.js": "^4.5.1",
    "docx": "^9.5.2",
    "express": "^5.1.0",
    "file-saver": "^2.0.5",
    "firebase": "^12.9.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.0.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "ng2-charts": "^8.0.0",
    "pdfjs-dist": "^4.10.38",
    "rxjs": "~7.8.0",
    "tesseract.js": "^7.0.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@types/express": "^5.0.1",
    "@types/html2canvas": "^0.5.35",
    "@types/html2pdf.js": "^0.10.0",
    "@types/node": "^20.17.19",
    "@types/node-fetch": "^2.6.13",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.4.2",
    "jsdom": "^27.1.0",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.0",
    "vitest": "^3.2.4"
  }
